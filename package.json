{
  "name": "knife",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/vercel-build.cjs",
    "build:local": "prisma generate && next build --webpack",
    "vercel:env": "node scripts/vercel-env-sync.cjs",
