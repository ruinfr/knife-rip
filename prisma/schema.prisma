// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Auth.js adapter — https://authjs.dev/reference/adapter/prisma

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?
  refresh_token_expires_in Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                  String    @id @default(cuid())
  name                String?
  email               String?
  emailVerified       DateTime?
  image               String?
  stripeCustomerId    String?   @unique
  /// Set when user completes one-time Knife Pro (lifetime) checkout.
  lifetimePremiumAt   DateTime?

  accounts     Account[]
  sessions     Session[]
  subscription Subscription?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String   @unique
  stripePriceId        String
  status               String
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

/// Idempotent Stripe webhook processing (store event.id)
model ProcessedStripeEvent {
  id         String   @id
  receivedAt DateTime @default(now())
}

/// Latest command list pushed by the Discord bot (single row id = "default").
model BotCommandSnapshot {
  id        String   @id
  payload   Json
  updatedAt DateTime @updatedAt
}

/// Runtime handouts (`.handout`) — merged with static IDs in `lib/bot-owners.ts` / `lib/knife-premium.ts`.
enum DiscordPrivilegeKind {
  OWNER
  PREMIUM
}

model DiscordPrivilege {
  id                 String               @id @default(cuid())
  discordUserId      String
  kind               DiscordPrivilegeKind
  grantedByDiscordId String?
  createdAt          DateTime             @default(now())

  @@unique([discordUserId, kind])
  @@index([discordUserId])
}
