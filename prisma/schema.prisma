// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Auth.js adapter — https://authjs.dev/reference/adapter/prisma

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?
  refresh_token_expires_in Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                  String    @id @default(cuid())
  name                String?
  email               String?
  emailVerified       DateTime?
  image               String?
  stripeCustomerId    String?   @unique
  /// Set when user completes one-time Knife Pro (lifetime) checkout.
  lifetimePremiumAt   DateTime?

  accounts     Account[]
  sessions     Session[]
  subscription Subscription?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String   @unique
  stripePriceId        String
  status               String
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

/// Idempotent Stripe webhook processing (store event.id)
model ProcessedStripeEvent {
  id         String   @id
  receivedAt DateTime @default(now())
}

/// Latest command list pushed by the Discord bot (single row id = "default").
model BotCommandSnapshot {
  id        String   @id
  payload   Json
  updatedAt DateTime @updatedAt
}

/// Guilds where the bot is turned off (`.access no` — bot owner only). Absence = allowed.
model BotGuildDenylist {
  guildId          String   @id
  setByDiscordId   String?
  createdAt        DateTime @default(now())
}

/// Per-guild bot settings (e.g. custom prefix). Absence = defaults.
model BotGuildSettings {
  guildId         String   @id
  commandPrefix   String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// `.command disable` — command blocked for everyone in scope (unless ALLOW override).
model BotGuildCommandDisable {
  id           String   @id @default(cuid())
  guildId      String
  commandKey   String
  /// `"*"` = all channels; else channel snowflake (see thread → parent channel).
  channelScope String
  createdAt    DateTime @default(now())

  @@unique([guildId, commandKey, channelScope])
  @@index([guildId])
}

enum BotCommandRoleOverrideEffect {
  /// Role may use the command even when disabled for the scope.
  ALLOW
  /// Role may not use the command in the scope even when not globally disabled.
  DENY
}

/// `.command override` — per-role ALLOW (bypass disable) or DENY (block).
model BotGuildCommandRoleOverride {
  id           String                       @id @default(cuid())
  guildId      String
  commandKey   String
  roleId       String
  channelScope String
  effect       BotCommandRoleOverrideEffect
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt

  @@unique([guildId, commandKey, roleId, channelScope])
  @@index([guildId])
}

/// Per-member text activity — human messages in guild text channels (best-effort increment).
model BotGuildMemberTextStats {
  guildId      String
  userId       String
  messageCount Int      @default(0)
  updatedAt    DateTime @updatedAt

  @@id([guildId, userId])
  @@index([guildId, messageCount(sort: Desc)])
}

/// Per-member cumulative time in voice (seconds); excludes AFK channel; in-memory sessions lost on restart.
model BotGuildMemberVoiceStats {
  guildId      String
  userId       String
  voiceSeconds BigInt   @default(0)
  updatedAt    DateTime @updatedAt

  @@id([guildId, userId])
  @@index([guildId, voiceSeconds(sort: Desc)])
}

/// Prefix commands actually run in a guild (metadata only — no message body or args).
model BotGuildCommandAudit {
  id          String   @id @default(cuid())
  guildId     String
  actorUserId String
  commandKey  String
  /// false = handler threw before completing; true = finished without throwing.
  success     Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([guildId, createdAt])
  @@index([createdAt])
}

/// Runtime handouts (`.handout`) — merged with static IDs in `lib/bot-owners.ts` / `lib/knife-premium.ts`.
enum DiscordPrivilegeKind {
  OWNER
  PREMIUM
}

model DiscordPrivilege {
  id                 String               @id @default(cuid())
  discordUserId      String
  kind               DiscordPrivilegeKind
  grantedByDiscordId String?
  createdAt          DateTime             @default(now())

  @@unique([discordUserId, kind])
  @@index([discordUserId])
}

/// Developer-only: opt out a Discord ID from `lib/bot-owners.ts` without redeploying.
model BootstrapOwnerRevocation {
  discordUserId        String   @id
  revokedByDiscordId String?
  createdAt            DateTime @default(now())
}

/// VoiceMaster (temporary VCs) — one row per guild with hub + panel + defaults.
model VoiceMasterGuildConfig {
  id                  String   @id @default(cuid())
  guildId             String   @unique
  hubChannelId        String
  panelChannelId      String
  categoryId          String
  privateCategoryId   String?
  defaultNameTemplate String   @default("{user}'s channel")
  defaultBitrate      Int      @default(64000)
  /// Discord voice region id, or null for automatic
  defaultRegion       String?
  /// Role copied into permission overwrites for new temp channels (optional)
  defaultRoleId       String?
  /// Role granted when joining a temp VC, removed when leaving (optional)
  joinRoleId          String?
  defaultInterface    Boolean  @default(false)
  panelMessageId      String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

/// Spawned temporary voice channel — deleted when empty.
model VoiceMasterTempChannel {
  id        String   @id @default(cuid())
  channelId String   @unique
  guildId   String
  ownerId   String
  /// Optional status shown in channel name (suffix) or topic-style tracking
  statusLabel String?
  musicOnly   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([guildId])
  @@index([ownerId])
}

/// Global per-Discord-user wallet (not per-server).
model EconomyUser {
  discordUserId      String    @id
  cash               BigInt    @default(0)
  bankCash           BigInt    @default(0)
  /// 0 = starter cap; higher tiers unlock larger `bankCash` caps.
  bankTier           Int       @default(0)
  lastBankInterestAt DateTime?
  lifetimeMessages   Int       @default(0)
  /// Highest 50-msg tier already paid (0, 50, 100, …). Each step grants +10; every 100 grants +50 extra.
  milestoneLastPaid50 Int      @default(0)
  /// Next index into `MILESTONE_HIGH_THRESHOLDS` (500 / 1k / 3k one-time bonuses).
  nextMilestoneIndex Int       @default(0)
  gambleWins         Int       @default(0)
  gambleLosses       Int       @default(0)
  gambleNetProfit    BigInt    @default(0)
  gambleWinStreak    Int       @default(0)
  gambleBestStreak   Int       @default(0)
  lastPayAt          DateTime?
  /// Last `.daily` claim (24h cooldown).
  lastDailyAt        DateTime?
  /// Knife Cash disclaimer completed at least once (global; skips repeat prompts).
  gambleDisclaimerAcceptedAt DateTime?
  lastWorkAt         DateTime?
  lastCrimeAt        DateTime?
  lastBegAt          DateTime?
  lastRobAt          DateTime?
  lastMineAt         DateTime?
  lastFishAt         DateTime?
  /// Equipped gathering pole for `.fish` (minigame + payout band).
  fishingPoleEquipped String   @default("twig")
  /// JSON string[] of owned pole keys (always includes free `twig` once migrated).
  fishingPolesOwned   Json?
  /// Equipped pickaxe for `.mine` (minigame + ore payout band).
  miningPickEquipped String   @default("wood")
  /// JSON string[] of owned pickaxe keys (always includes free `wood` once normalized).
  miningPicksOwned   Json?
  /// Equipped job tier for `.work` (minigame + gross pay band).
  workJobEquipped String   @default("intern")
  /// JSON string[] of owned job keys (always includes free `intern` once normalized).
  workJobsOwned   Json?
  /// Victim-side: last successful robbery (anti chain-rob).
  lastRobbedAt       DateTime?
  /// Count of successful robberies against this user (UTC day in `robVictimDay`).
  robVictimCount     Int       @default(0)
  robVictimDay       String?
  /// Throttle randomized `.business` events (rush, inspection, etc.).
  businessEventLastRollAt DateTime?
  /// Times the user has rebirthed (soft reset); drives permanent bonuses.
  rebirthCount       Int       @default(0)
  /// Spend in `.rebirth` gem shop (earned each rebirth).
  rebirthGems        BigInt    @default(0)
  lastRebirthAt      DateTime?
  /// JSON: { coin?: number, daily?: number, rob?: number, petXp?: number } — shop levels 0–5.
  rebirthShop        Json?
  /// In-progress Knife Cash web blackjack hand (server-side). Cleared when the hand ends or expires.
  webBlackjackState  Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  pets          EconomyPet[]
  businessSlots EconomyBusinessSlot[]
  businessEvents EconomyBusinessEvent[]
}

model EconomyLedger {
  id             String   @id @default(cuid())
  discordUserId  String
  delta          BigInt
  balanceAfter   BigInt
  reason         String
  meta           Json?
  actorUserId    String?
  createdAt      DateTime @default(now())

  @@index([discordUserId, createdAt])
}

/// Role shop — roles must exist in the hub guild (see ECONOMY_LOG_CHANNEL_ID).
model EconomyShopItem {
  id        String  @id @default(cuid())
  emoji     String
  name      String
  price     Int
  roleId    String
  sortOrder Int     @default(0)
  active    Boolean @default(true)
}

model EconomyGambleLog {
  id            String   @id @default(cuid())
  discordUserId String
  game          String
  bet           BigInt
  payout        BigInt
  won           Boolean
  createdAt     DateTime @default(now())

  @@index([discordUserId, createdAt])
}

/// PVP coinflip challenge — money moves only when opponent accepts (atomic settle).
model EconomyCoinflipPvpChallenge {
  id                  String    @id @default(cuid())
  guildId             String
  channelId           String
  messageId           String?
  challengerDiscordId String
  opponentDiscordId   String
  bet                 BigInt
  status              String    @default("pending")
  winnerDiscordId     String?
  /// Heads = Challenger wins, Tails = Opponent wins (set when completed).
  outcomeHeads        Boolean?
  expiresAt           DateTime
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([status, expiresAt])
  @@index([opponentDiscordId, status])
}

model EconomyPet {
  id         String      @id @default(cuid())
  ownerId    String
  owner      EconomyUser @relation(fields: [ownerId], references: [discordUserId], onDelete: Cascade)
  speciesKey String
  nickname   String?
  xp         Int         @default(0)
  happiness  Int         @default(100)
  equipped   Boolean     @default(false)
  createdAt  DateTime    @default(now())

  @@index([ownerId])
  @@index([ownerId, equipped])
}

model EconomyBusinessSlot {
  id              String      @id @default(cuid())
  ownerId         String
  owner           EconomyUser @relation(fields: [ownerId], references: [discordUserId], onDelete: Cascade)
  businessKey     String
  tier            Int         @default(1)
  lastCollectedAt DateTime    @default(now())
  /// 📈 Marketing — % income (see economy tuning).
  marketingLevel   Int        @default(0)
  /// ⚡ Automation — extra accrue cap + silent collect on menu open.
  automationLevel  Int        @default(0)
  /// 🧑‍💼 Staff — mitigates inspection penalties.
  staffLevel       Int        @default(0)
  /// 🛠️ Equipment — boosts effective hourly rate.
  equipmentLevel   Int        @default(0)
  /// Temporary income debuff (e.g. ignored fire), basis points; cleared when `debuffUntil` passes.
  debuffBps        Int        @default(0)
  debuffUntil      DateTime?
  createdAt       DateTime    @default(now())

  @@unique([ownerId, businessKey])
  @@index([ownerId])
}

/// Time-limited randomized business events (per owner + site).
model EconomyBusinessEvent {
  id          String      @id @default(cuid())
  ownerId     String
  owner       EconomyUser @relation(fields: [ownerId], references: [discordUserId], onDelete: Cascade)
  businessKey String
  /// rush_hour | inspection | tip_jar | fire
  kind        String
  startsAt    DateTime    @default(now())
  expiresAt   DateTime
  resolved    Boolean     @default(false)
  meta        Json?
  createdAt   DateTime    @default(now())

  @@index([ownerId, resolved, expiresAt])
}

/// Stake duel (rake to treasury) — settle when opponent accepts.
model EconomyDuel {
  id                  String    @id @default(cuid())
  guildId             String
  channelId           String
  messageId           String?
  challengerDiscordId String
  opponentDiscordId   String
  stake               BigInt
  status              String    @default("pending")
  winnerDiscordId     String?
  expiresAt           DateTime
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([status, expiresAt])
  @@index([opponentDiscordId, status])
}

/// Open bounty on a member; MVP payout when someone successfully `.rob`s the target in the same guild.
model EconomyBounty {
  id                String    @id @default(cuid())
  posterDiscordId   String
  targetDiscordId   String
  amount            BigInt
  guildId           String
  status            String    @default("open")
  claimerDiscordId  String?
  createdAt         DateTime  @default(now())
  fulfilledAt       DateTime?

  @@index([guildId, status])
  @@index([targetDiscordId, status])
}

/// Per-guild jail (`.jailsetup`) — role + channels for `.jail` / `.unjail`.
model BotGuildJailConfig {
  guildId           String   @id
  jailRoleId        String
  jailChannelId     String
  logChannelId      String
  categoryId        String?
  /// Highest role of whoever ran setup; used for channel view overwrites when not @everyone.
  staffAccessRoleId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/// Member currently jailed — restored roles in `removedRoleIds` (JSON string[]).
model BotGuildJailMember {
  id              String    @id @default(cuid())
  guildId         String
  userId          String
  removedRoleIds  Json
  reason          String?
  jailedByUserId  String?
  jailedAt        DateTime  @default(now())
  /// When set, auto-unjail at this time (optional).
  releaseAt       DateTime?

  @@unique([guildId, userId])
  @@index([guildId])
  @@index([guildId, releaseAt])
}

/// `.webhook lock` — only `lockedByUserId` may use Knife webhook send/edit/delete for that webhook.
model BotGuildWebhookLock {
  id             String   @id @default(cuid())
  guildId        String
  webhookId      String   @unique
  lockedByUserId String
  createdAt      DateTime @default(now())

  @@index([guildId])
}

// --- Moderation mega-suite (mod cases, notes, bans, lockdown, roles) ---

enum BotModCaseKind {
  WARN
  BAN
  UNBAN
  KICK
  SOFTBAN
  TEMPBAN
  TIMEOUT
  JAIL
  UNJAIL
  MUTE
  UNMUTE
  UNMUTE_ROLE
  HARD_BAN
  PURGE
  STRIPSTAFF
  RAID
  OTHER
}

/// Guild-scoped moderation case (sequential caseNum per guild).
model BotGuildModCase {
  id           String         @id @default(cuid())
  guildId      String
  caseNum      Int
  kind         BotModCaseKind
  actorUserId  String
  targetUserId String
  reason       String?        @db.Text
  metadata     Json?
  createdAt    DateTime       @default(now())

  proofs BotGuildModCaseProof[]

  @@unique([guildId, caseNum])
  @@index([guildId, targetUserId])
  @@index([guildId, actorUserId])
  @@index([guildId, createdAt])
}

model BotGuildModCaseProof {
  id        String          @id @default(cuid())
  modCaseId String
  modCase   BotGuildModCase @relation(fields: [modCaseId], references: [id], onDelete: Cascade)
  url       String?         @db.Text
  note      String?         @db.Text
  sortIndex Int             @default(0)
  createdAt DateTime        @default(now())

  @@index([modCaseId])
}

model BotGuildMemberNote {
  id          String   @id @default(cuid())
  guildId     String
  userId      String
  authorId    String
  body        String   @db.Text
  createdAt   DateTime @default(now())

  @@index([guildId, userId])
}

/// Re-ban on join when set.
model BotGuildHardban {
  guildId       String
  userId        String
  reason        String?  @db.Text
  createdById   String?
  createdAt     DateTime @default(now())

  @@id([guildId, userId])
  @@index([guildId])
}

/// Channels skipped by lockdown all / unlock all.
model BotGuildLockdownIgnore {
  guildId   String
  channelId String
  createdAt DateTime @default(now())

  @@id([guildId, channelId])
  @@index([guildId])
}

/// Active lockdown-all session: channel ids that were locked.
model BotGuildLockdownSession {
  id         String   @id @default(cuid())
  guildId    String
  channelIds Json
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([guildId, active])
}

model BotGuildTempRoleGrant {
  id        String   @id @default(cuid())
  guildId   String
  userId    String
  roleId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([guildId, expiresAt])
  @@index([guildId, userId])
}

model BotGuildStickyRole {
  guildId String
  userId  String
  roleId  String
  setById String?
  createdAt DateTime @default(now())

  @@id([guildId, userId, roleId])
  @@index([guildId])
}

model BotGuildForcedNickname {
  guildId   String
  userId    String
  nickname  String
  setById   String?
  createdAt DateTime @default(now())

  @@id([guildId, userId])
}

/// Only these roles may use commandKey in guild (exclusive allowlist). Empty for a cmd = not restricted.
model BotGuildCommandRestrictAllow {
  id          String   @id @default(cuid())
  guildId     String
  commandKey  String
  roleId      String
  createdAt   DateTime @default(now())

  @@unique([guildId, commandKey, roleId])
  @@index([guildId, commandKey])
}

model BotGuildScheduledUnban {
  id          String   @id @default(cuid())
  guildId     String
  userId      String
  expiresAt   DateTime
  actorUserId String?
  reason      String?  @db.Text
  createdAt   DateTime @default(now())

  @@unique([guildId, userId])
  @@index([guildId, expiresAt])
}

/// Muted role id after `.setupmute`.
model BotGuildMuteConfig {
  guildId      String   @id
  mutedRoleId  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Last known roles for `.role restore` (non-jail).
model BotGuildMemberRoleSnapshot {
  guildId    String
  userId     String
  roleIds    Json
  updatedAt  DateTime @updatedAt

  @@id([guildId, userId])
}

/// Optional modlog channel per guild.
model BotGuildModSettings {
  guildId          String   @id
  modLogChannelId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

/// Nuke schedule per channel (optional phase-2 persistence).
model BotGuildNukeSchedule {
  id          String   @id @default(cuid())
  guildId     String
  channelId   String
  intervalMs  Int
  messageText String?  @db.Text
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@unique([guildId, channelId])
}

/// Keyword highlights — subscribers get a DM when a keyword appears (per guild).
model BotGuildHighlightKeyword {
  id        String   @id @default(cuid())
  guildId   String
  userId    String
  keyword   String   @db.Text
  createdAt DateTime @default(now())

  @@unique([guildId, userId, keyword])
  @@index([guildId])
}

/// Per-subscriber ignore rules for highlight DMs.
model BotGuildHighlightIgnore {
  id             String   @id @default(cuid())
  guildId        String
  subscriberId   String
  targetType     String
  targetId       String
  createdAt      DateTime @default(now())

  @@unique([guildId, subscriberId, targetType, targetId])
  @@index([guildId, subscriberId])
}

model BotGuildBirthdaySettings {
  guildId           String   @id
  announceChannelId String?
  roleId            String?
  celebrateRoleId String?
  locked            Boolean  @default(false)
  updatedAt         DateTime @updatedAt
}

model BotGuildMemberBirthday {
  guildId   String
  userId    String
  month     Int
  day       Int
  year      Int?
  unlocked  Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@id([guildId, userId])
}

model BotUserTimezone {
  userId    String   @id
  iana      String
  updatedAt DateTime @updatedAt
}

model BotGuildUserLastSeen {
  guildId    String
  userId     String
  lastSeenAt DateTime @updatedAt

  @@id([guildId, userId])
}

/// Aggregated custom emoji usage from message content (best-effort).
model BotGuildEmojiUsage {
  guildId String
  emojiId String
  uses    Int     @default(0)

  @@id([guildId, emojiId])
}

model BotGuildBoosterEvent {
  id      String   @id @default(cuid())
  guildId String
  userId  String
  kind    String
  at      DateTime @default(now())

  @@index([guildId, at])
}

/// Roles assigned automatically on member join.
model BotGuildAutorole {
  id        String   @id @default(cuid())
  guildId   String
  roleId    String
  createdAt DateTime @default(now())

  @@unique([guildId, roleId])
  @@index([guildId])
}

/// Reaction → role bindings (message must be reachable by the bot).
model BotGuildReactionRole {
  id        String   @id @default(cuid())
  guildId   String
  channelId String
  messageId String
  emojiKey  String
  roleId    String
  createdAt DateTime @default(now())

  @@unique([guildId, channelId, messageId, emojiKey])
  @@index([guildId])
  @@index([channelId, messageId])
}

/// Guild flag: re-apply reaction-granted roles on rejoin (persist table below).
model BotGuildReactionRoleSettings {
  guildId         String   @id
  restoreOnRejoin Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}

/// Persists reaction-role grants for restore-on-rejoin (cleared on unreact; optionally cleared on leave).
model BotGuildReactionRoleGrant {
  guildId String
  userId  String
  roleId  String

  @@id([guildId, userId, roleId])
  @@index([guildId, userId])
}

/// Button on a **bot-sent** message that toggles a role.
model BotGuildButtonRole {
  id          String   @id @default(cuid())
  guildId     String
  channelId   String
  messageId   String
  roleId      String
  style       Int
  label       String
  emojiJson   String?
  sortIndex   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([guildId])
  @@index([guildId, channelId, messageId])
}

/// One-confirmation watch for a Bitcoin tx (mempool.space); notify then delete row.
model BotBtcTxWatch {
  id        String   @id @default(cuid())
  userId    String
  guildId   String?
  channelId String?
  txHash    String
  createdAt DateTime @default(now())

  @@unique([userId, txHash])
  @@index([txHash])
}

/// Dictionary-driven invite slug observation (GET invite by code, same as discord.gg links).
model VanityInviteObservation {
  code             String    @id
  wasValid         Boolean   @default(false)
  guildId          String?
  guildName        String?
  lastCheckedAt    DateTime  @default(now())
  firstSeenValidAt DateTime?
  /// Set when `wasValid` transitions true → false (invite stopped resolving).
  droppedAt        DateTime?

  @@index([droppedAt])
}

/// Single-row cursor into the filtered vanity word list (singleton id = 1).
model VanityScannerCheckpoint {
  id        Int      @id
  nextIndex Int      @default(0)
  updatedAt DateTime @updatedAt
}
