# App URL (Auth.js / OAuth callbacks). Local: http://localhost:3000 — prod: https://knife.rip
AUTH_URL="http://localhost:3000"
# Generate: openssl rand -base64 32
AUTH_SECRET=""

# Optional: canonical site URL for Stripe redirects if AUTH_URL unset
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# PostgreSQL (e.g. Neon, Supabase, local Docker — see README).
# Vercel: add in Project → Settings → Environment Variables for Production (and Preview if you use it).
# Runtime needs a real URL; builds no longer require it at module load (see lib/db.ts).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Discord — https://discord.com/developers/applications
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_BOT_TOKEN=""

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# One-time Pro price — $10 USD, one-time (not recurring), in Stripe Dashboard → Products
STRIPE_PRICE_PRO_LIFETIME=""

# Optional: Plausible Analytics (https://plausible.io) — your site domain in Plausible
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""

# Bot ↔ site shared secret (required for command sync + premium API from the bot)
# 1) Generate once:  openssl rand -hex 32
# 2) Put the SAME string here AND in any machine that runs the Discord bot (same repo .env is fine).
# 3) Site uses it for: GET /api/internal/entitlement, POST /api/internal/commands
# 4) Bot sends: Authorization: Bearer <this value>
# 5) Start the Next site (npm run dev) before the bot so sync can reach the API.
BOT_INTERNAL_SECRET=""
# Optional: where the bot calls the Next app (entitlement + command sync). Use your public site origin,
# e.g. https://knife.rip or https://your-app.vercel.app — no path, no trailing slash.
# If unset, the bot uses AUTH_URL, then NEXT_PUBLIC_SITE_URL, then http://localhost:3000.
SITE_API_BASE_URL=""

# Public bot invite (OAuth2 URL); use your Client ID from the Developer Portal
NEXT_PUBLIC_DISCORD_INVITE_URL=""
