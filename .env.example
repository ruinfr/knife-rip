# ── URLs (Auth.js / OAuth / Stripe redirects) ─────────────────────────────
# Local: http://localhost:3000  |  Production: https://your-domain.vercel.app or https://knife.rip
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Generate: openssl rand -base64 32 (required in production)
AUTH_SECRET=""
# Optional: AUTH_DEBUG=1 on Vercel → redeploy → sign in → read Function logs → remove when fixed

# ── Database (Neon / Supabase / RDS / Docker) ───────────────────────────────
# Vercel: add in Project → Environment Variables (Production + Preview).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# ── Discord (https://discord.com/developers/applications) ──────────────────
# OAuth2 → Redirects must include: {AUTH_URL}/api/auth/callback/discord
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
# Bot token (same app) — dashboard guild list, role sync, etc.
DISCORD_BOT_TOKEN=""

# knife.rip hub — set **guild id** so Vercel + bot sync Discord roles to entitlement (Stripe + .handout).
# Role IDs default in code: Pro 1490510690429964379, Owner 1490510979380023446, Dev 1490510979157594243.
# Override with KNIFE_RIP_*_ROLE_ID if you recreate roles. Bot role must be **above** these. Server Members Intent on.
# KNIFE_RIP_GUILD_ID=""
# KNIFE_RIP_PREMIUM_ROLE_ID=""
# KNIFE_RIP_OWNER_ROLE_ID=""
# KNIFE_RIP_DEVELOPER_ROLE_ID=""

# ── Stripe (https://dashboard.stripe.com/apikeys) ──────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_PRO_LIFETIME=""

# ── Optional analytics ──────────────────────────────────────────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""

# ── Bot ↔ site (command sync + entitlement + .handout) ────────────────────
# Same value on Vercel and wherever the bot runs. openssl rand -hex 32
BOT_INTERNAL_SECRET=""
# Base URL of this Next app (no trailing slash). Bot handouts / entitlement call this — use your
# **production** URL (e.g. https://knife.rip) when the bot does not run on the same machine as `next dev`.
SITE_API_BASE_URL=""
# Run migrations after pull: npx prisma migrate deploy
# Handouts: .handout @user add|remove owner|premium → DiscordPrivilege (no redeploy).
# Optional: comma-separated snowflakes — merged with lib/bot-developers.ts (Developer tier).
# DEVELOPER_DISCORD_IDS=""

# ── RapidAPI (optional — `.tiktok`) ───────────────────────────────────────────
# https://rapidapi.com/tikfly/api/tiktok-api23
RAPIDAPI_KEY=""

# ── Public bot invite (OAuth2 URL with scope=bot) ──────────────────────────
NEXT_PUBLIC_DISCORD_INVITE_URL=""

# Official Discord hub (Pro/owner/dev role sync). Defaults to https://discord.gg/tCkFcqcPwk if unset/invalid.
# NEXT_PUBLIC_DISCORD_COMMUNITY_INVITE_URL=""
# COMMUNITY_DISCORD_INVITE_URL=""
